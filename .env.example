# ══════════════════════════════════════════════════════
#  AI TRADE BOT — Variáveis de Ambiente
#  Copie este arquivo para .env e preencha os valores
# ══════════════════════════════════════════════════════

# ── Bybit API ──────────────────────────────────────────
# Crie sua API em: https://www.bybit.com/app/user/api-management
# Permissões necessárias: Trade (Read + Write), Positions (Read)
BYBIT_API_KEY=sua_api_key_aqui
BYBIT_API_SECRET=seu_api_secret_aqui

# true = testnet (modo de teste) | false = mainnet (dinheiro real)
# SEMPRE comece com true para testar!
BYBIT_TESTNET=true

# ── Telegram Bot ───────────────────────────────────────
# 1. Fale com @BotFather no Telegram → /newbot
# 2. Copie o token gerado abaixo
# 3. Inicie uma conversa com o bot e acesse:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    para pegar seu chat_id
TELEGRAM_BOT_TOKEN=seu_token_aqui
TELEGRAM_CHAT_ID=seu_chat_id_aqui

# ── Groq AI (GRATUITO) ────────────────────────────────
# 1. Acesse: https://console.groq.com
# 2. Faça login com Google/GitHub (sem cartão)
# 3. Vá em "API Keys" → "Create API Key"
# Modelo usado: llama-3.3-70b-versatile (gratuito)
GROQ_API_KEY=sua_chave_groq_aqui

# ── OLLAMA (Local, Ilimitado) ──────────────────────────
# 1. Baixe: https://ollama.ai
# 2. Instale e rode: ollama pull mistral
# 3. Deixe em localhost:11434 (padrão)
# ✅ Ilimitado, sem custo, rápido, privado
OLLAMA_URL=http://localhost:11434

# ── TOGETHER AI (Cloud, ~100/dia grátis) ──────────────
# 1. Crie conta: https://www.together.ai/
# 2. Gere API key em Settings → API Keys
# 3. Cole aqui (deixe vazio se não usar)
# ✅ Cloud backup, bom se Ollama offline
TOGETHER_API_KEY=sua_chave_together_aqui

# ═══════════════════════════════════════════════════════
#  ⚡ ORDEM DE TENTATIVA DE IA:
#  1. OLLAMA (local, mais rápido)
#  2. TOGETHER AI (cloud, backup)
#  3. FALLBACK (análise calculada, sem IA)
# ═══════════════════════════════════════════════════════
